.DS_Store
result
iso/nixos.iso
.aider*
.env
.qodo
.claude/worktrees/
.claude/scheduled_tasks.lock
backup.tar.gz
settings.local.json
CLAUDE.local.md

# Beads local/runtime files
.beads/daemon-error

# MCP Agent Mail (installed via its own script, not managed by Nix)
mcp_agent_mail/

# Ralph Wiggum loop runtime state (sessions, logs, metrics)
.ralph/sessions/
.ralph/latest
.ralph/history.jsonl

# SLB state (don't commit pending requests)
.slb/

# PAI repo (installed via chezmoi to ~/.claude/PAI/, not part of Nix config)
Personal_AI_Infrastructure/

# Plan-mode scratchpad files. Plan mode auto-generates filenames like
# "Plans/now-<slug>.md". Those are session-internal scratch and shouldn't be
# committed. Intentional plan docs with descriptive names — e.g.
# "Plans/add-hermes-agent.md" — are fine to commit.
Plans/now-*.md
